<Window x:Class="WatchMark.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WatchMark - Track Your Movies"
        Height="640"
        Width="980"
        MinHeight="500"
        MinWidth="760"
        Icon="app.ico">
    <Grid Margin="16">
        <Grid.Resources>
            <Style x:Key="MovieTextStyle" TargetType="TextBlock">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsWatched}" Value="True">
                        <Setter Property="TextDecorations" Value="Strikethrough" />
                        <Setter Property="Opacity" Value="0.65" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Library:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <Grid Grid.Column="1" Margin="0,0,8,0">
                <ComboBox x:Name="LibraryPathComboBox"
                          IsEditable="False"
                          SelectedItem="{Binding SelectedLibraryPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding RecentLibraryPaths}"
                          VerticalContentAlignment="Center"
                          SelectionChanged="LibraryPathComboBox_SelectionChanged" />
                <TextBlock IsHitTestVisible="False"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="5,0,0,0"
                           Text="{Binding SelectedLibraryPath, TargetNullValue='(select library...)'}"
                           TextTrimming="CharacterEllipsis"
                           Opacity="0.6"
                           Foreground="Gray" />
            </Grid>
            <Button Grid.Column="2" Content="Browse..." Width="80" Command="{Binding BrowseCommand}" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                       FontSize="18" 
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" 
                       Margin="0,0,16,0"
                       TextTrimming="CharacterEllipsis">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="{Binding CurrentFolderName}" />
                        <Setter Property="Foreground" Value="Black" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentFolderName}" Value="">
                                <Setter Property="Text" Value="(no library selected)" />
                                <Setter Property="Foreground" Value="Gray" />
                                <Setter Property="FontWeight" Value="Normal" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentFolderName}" Value="{x:Null}">
                                <Setter Property="Text" Value="(no library selected)" />
                                <Setter Property="Foreground" Value="Gray" />
                                <Setter Property="FontWeight" Value="Normal" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            
            <TextBox Grid.Column="1"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center"
                     Margin="0,0,8,0"
                     Height="28">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="🔍 Filter movies..." Foreground="Gray" Margin="4,0,0,0" />
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,16,0">
                <Button Content="Mark Watched" Width="120" Command="{Binding MarkSelectedWatchedCommand}" Margin="0,0,8,0" />
                <Button Content="Mark Unwatched" Width="130" Command="{Binding MarkSelectedUnwatchedCommand}" />
            </StackPanel>
            
            <TextBlock Grid.Column="3" Text="{Binding StatusText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
        </Grid>

        <DataGrid Grid.Row="2"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding FilteredMovies}"
                  SelectedItem="{Binding SelectedMovie}"
                  MouseDoubleClick="MoviesGrid_MouseDoubleClick"
                  IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="✔"
                                       HorizontalAlignment="Center"
                                       FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsWatched}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*" ElementStyle="{StaticResource MovieTextStyle}" IsReadOnly="True" />
                <DataGridTextColumn Header="Duration" Binding="{Binding DurationText}" Width="*" ElementStyle="{StaticResource MovieTextStyle}" IsReadOnly="True" />
                <DataGridTextColumn Header="Progress" Binding="{Binding ProgressText}" Width="*" ElementStyle="{StaticResource MovieTextStyle}" IsReadOnly="True" />
                <DataGridCheckBoxColumn Header="Watched" Binding="{Binding IsWatched}" Width="90" />
                <DataGridTextColumn Header="Last Watched" Binding="{Binding LastWatchedText}" Width="*" ElementStyle="{StaticResource MovieTextStyle}" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap"
                   Text="Tip: Double-click a movie to play in VLC. Progress is tracked automatically." />

    </Grid>
</Window>
