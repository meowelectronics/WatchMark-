<Window x:Class="WatchMark.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WatchMark - Track Your Movies"
        Height="720"
        Width="1200"
        MinHeight="600"
        MinWidth="900"
        Icon="app.ico"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Border Padding="32" Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.Resources>
            <Style x:Key="MovieTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsWatched}" Value="True">
                        <Setter Property="TextDecorations" Value="Strikethrough" />
                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                        <Setter Property="Opacity" Value="0.7" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Section - Removed, playlist tabs are sufficient -->

        <!-- Toolbar Section -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" MinWidth="260" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="280" MinWidth="180" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                       FontSize="24" 
                       FontWeight="Bold"
                       VerticalAlignment="Center" 
                       Margin="0,0,24,0"
                       HorizontalAlignment="Stretch"
                       TextTrimming="CharacterEllipsis">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="{Binding CurrentFolderName}" />
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentFolderName}" Value="">
                                <Setter Property="Text" Value="No Library Selected" />
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentFolderName}" Value="{x:Null}">
                                <Setter Property="Text" Value="No Library Selected" />
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            
            <Border Grid.Column="1" 
                   Background="White" 
                   CornerRadius="8" 
                   BorderBrush="{StaticResource BorderBrush}" 
                   BorderThickness="1"
                   Margin="0,0,16,0">
                <Grid>
                    <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             BorderThickness="0"
                             Height="42"
                             VerticalContentAlignment="Center" />
                    <TextBlock IsHitTestVisible="False"
                              Text="🔍 Search movies..."
                              VerticalAlignment="Center"
                              HorizontalAlignment="Left"
                              Margin="12,0,0,0"
                              Foreground="{StaticResource TextMutedBrush}"
                              FontSize="14">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilterText}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FilterText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
            
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,16,0">
                <Button Content="✓ Watched" 
                       Width="120" 
                       Style="{StaticResource ModernButton}"
                       Command="{Binding MarkSelectedWatchedCommand}" 
                       Margin="0,0,12,0" />
                <Button Content="○ Unwatched" 
                       Width="130" 
                       Style="{StaticResource SecondaryButton}"
                       Command="{Binding MarkSelectedUnwatchedCommand}" />
            </StackPanel>
            
            <StackPanel Grid.Column="3" Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock Text="{Binding VlcStatusText}" 
                          TextTrimming="CharacterEllipsis"
                          TextWrapping="NoWrap"
                          FontSize="12"
                          FontWeight="SemiBold"
                          Margin="0,0,0,4">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#10B981"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsVlcHttpConnected}" Value="False">
                                    <Setter Property="Foreground" Value="#F59E0B"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding StatusText}" 
                          TextTrimming="CharacterEllipsis"
                          TextWrapping="NoWrap"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="13" />
            </StackPanel>
        </Grid>

        <!-- Playlist Tabs -->
        <Border Grid.Row="2" 
               Background="White" 
               CornerRadius="12" 
               BorderBrush="{StaticResource BorderBrush}" 
               BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="16" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Tab Header with Add Button -->
                <Grid Grid.Row="0" Margin="16,16,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TabControl Grid.Column="0"
                               ItemsSource="{Binding Playlists}"
                               SelectedItem="{Binding SelectedPlaylist}"
                               BorderThickness="0"
                               Background="Transparent">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" 
                                              Padding="12,8,8,8"
                                              FontSize="14"
                                              FontWeight="Medium"
                                              MaxWidth="220"
                                              TextTrimming="CharacterEllipsis"
                                              VerticalAlignment="Center"/>
                                    <Button Content="🗑"
                                           FontSize="14"
                                           Padding="4,2"
                                           Margin="4,0,0,0"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           Foreground="#9CA3AF"
                                           Cursor="Hand"
                                           Command="{Binding DataContext.DeletePlaylistCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                           CommandParameter="{Binding}"
                                           ToolTip="Delete playlist">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Opacity" Value="0.6"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFixed}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <!-- Content is in the DataGrid below -->
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                    
                    <Button Grid.Column="1"
                           Content="+ New Playlist"
                           Style="{StaticResource SecondaryButton}"
                           Command="{Binding AddPlaylistCommand}"
                           Height="36"
                           Padding="16,8"/>
                </Grid>
                
                <!-- Movie DataGrid -->
                <DataGrid Grid.Row="1"
                          Margin="16,8,16,16"
                          AutoGenerateColumns="False"
                          ItemsSource="{Binding FilteredMovies}"
                          SelectedItem="{Binding SelectedMovie}"
                          MouseDoubleClick="MoviesGrid_MouseDoubleClick"
                          IsReadOnly="False"
                          Style="{StaticResource ModernDataGrid}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                          CellStyle="{StaticResource ModernDataGridCell}"
                          RowStyle="{StaticResource ModernDataGridRow}"
                          BorderThickness="0"
                          Background="Transparent">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SuccessBrush}" 
                                       CornerRadius="12" 
                                       Width="24" 
                                       Height="24"
                                       HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsWatched}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="✓"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Foreground="White"
                                              FontWeight="Bold"
                                              FontSize="12" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*" ElementStyle="{StaticResource MovieTextStyle}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Duration" Binding="{Binding DurationText}" Width="*" ElementStyle="{StaticResource MovieTextStyle}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Progress" Binding="{Binding ProgressText}" Width="80" ElementStyle="{StaticResource MovieTextStyle}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Stopped At" Binding="{Binding LastPositionText}" Width="100" ElementStyle="{StaticResource MovieTextStyle}" IsReadOnly="True" />
                    <DataGridCheckBoxColumn Header="Watched" Binding="{Binding IsWatched}" Width="100" />
                    <DataGridTextColumn Header="Last Watched" Binding="{Binding LastWatchedText}" Width="*" ElementStyle="{StaticResource MovieTextStyle}" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3"
               Margin="0,20,0,0"
               Background="#EEF2FF"
               CornerRadius="8"
               Padding="16,12"
               BorderBrush="#C7D2FE"
               BorderThickness="1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="💡" 
                              FontSize="16" 
                              Margin="0,0,8,0"
                              VerticalAlignment="Center" />
                    <TextBlock TextWrapping="Wrap"
                              Foreground="{StaticResource PrimaryBrush}"
                              FontSize="13"
                              FontWeight="Medium"
                              VerticalAlignment="Center">
                        <Run Text="Tip:"/>
                        <Run Text="Play any movie from Windows Explorer in VLC - it will be automatically detected and tracked!" FontWeight="Normal"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚙️" 
                              FontSize="14" 
                              Margin="0,0,8,0"
                              VerticalAlignment="Top" />
                    <TextBlock TextWrapping="Wrap"
                              Foreground="#6366F1"
                              FontSize="12"
                              VerticalAlignment="Center">
                        <Run Text="For progress tracking:" FontWeight="SemiBold"/>
                        <Run Text="Enable VLC HTTP: Tools → Preferences → Show All → Interface → Main interfaces → check 'Web' → Lua → HTTP → password: vlchttp → Restart VLC" FontWeight="Normal" Foreground="#64748B"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
    </Border>
</Window>
